  <property name="styleSheet">
   <string notr="true">
QMainWindow {
    background-color: #f4f7f6;
}

QLineEdit {
    border: 2px solid #bdc3c7;
    border-radius: 8px;
    padding: 8px;
    background: white;
    selection-background-color: #3498db;
    font-size: 14px;
}

/* When the user clicks into a box, make the border blue */
QLineEdit:focus {
    border: 2px solid #3498db;
}


QPushButton {
    background-color: #2c3e50;
    color: white;
    border-radius: 6px;
   
    padding: 6px 20px; 
    
    font-weight: bold;
    font-size: 13px;
    min-width: 80px;
    max-width: 120px;
}

QPushButton:hover {
    background-color: #34495e;
}

QPushButton:pressed {
    background-color: #1a252f;
}

QLabel {
    color: #2c3e50;
    font-family: &quot;Segoe UI&quot;, Arial;
}

QLineEdit {
    /* Reduce padding to shrink the height */
    padding: 4px 8px; 
    
    /* Smaller, cleaner font */
    font-size: 13px; 
    
    /* Thinner border and tighter radius */
    border: 1px solid #ced4da;
    border-radius: 4px; 
    
    background-color: white;
    color: #2c3e50;
    
    /* Keeps the box from expanding too much */
    min-height: 25px; 
}

/* Make the placeholder text slightly smaller to ensure it fits */
QLineEdit::placeholder {
    font-size: 12px;
    color: #999;
}

QLineEdit:focus {
    border: 1.5px solid #3498db;
    background-color: #fcfcfc;
}</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QHBoxLayout" name="horizontalLayout">
    <item>
     <widget class="QStackedWidget" name="mainStack">
      <property name="styleSheet">
       <string notr="true">/* Main Page Background */
#mainStack {
    background-color: #f0f2f5;
    font-family: &quot;Segoe UI&quot;, Arial;
}

/* Account Info Card */
#lblDisplay {
    background-color: #ffffff;
    border: 1px solid #d1d8e0;
    border-radius: 12px;
    padding: 15px;
    color: #2d3436;
    font-size: 15px;
}

/* All Input Boxes */
QLineEdit {
    background-color: #ffffff;
    border: 2px solid #ced4da;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 13px;
    color: #495057;
}

QLineEdit:focus {
    border: 2px solid #0984e3;
    background-color: #f8fbff;
}

/* Standard Action Buttons (Deposit, Withdraw, Update) */
QPushButton {
    background-color: #0984e3;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #74b9ff;
}

QPushButton:pressed {
    background-color: #074b83;
}

/* Specific Navigation/Danger Buttons */
#btnLogout {
    background-color: #636e72;
}

#btnLogout:hover {
    background-color: #b2bec3;
}

#btnDeleteAccount {
    background-color: transparent;
    color: #d63031;
    border: 1px solid #d63031;
}

#btnDeleteAccount:hover {
    background-color: #d63031;
    color: white;
}

/* The &quot;X&quot; Exit Button */
#btnExit {
    background-color: #d63031;
    color: white;
    font-weight: bold;
    border-radius: 4px;
}

#btnExit:hover {
    background-color: #ff7675;
}

/* Status Bar Styling */
QStatusBar {
    background-color: #dfe6e9;
    color: #2d3436;
    font-style: italic;
}
#btnGoToSignUp {
    background-color: transparent;
    color: #3498db;
    text-decoration: underline;
    border: none;
    font-size: 12px;
}
#btnGoToSignUp:hover {
    color: #2980b9;
}</string>
